APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
APP_PORT=8000
FORWARD_DB_PORT=3310
PHPMYADMIN_PORT=8081
FORWARD_REDIS_PORT=6379
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=${FORWARD_DB_PORT}
DB_DATABASE=rental_management
DB_USERNAME=laravel
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=${FORWARD_REDIS_PORT}

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=${MAILPIT_SMTP_PORT}
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

NOTIFICATIONS_WHATSAPP_DRIVER=log
NOTIFICATIONS_WHATSAPP_LOG_CHANNEL=stack
NOTIFICATIONS_WHATSAPP_TIMEOUT_SECONDS=10
NOTIFICATIONS_WHATSAPP_VERIFY_SSL=true
NOTIFICATIONS_WHATSAPP_CA_BUNDLE=
WPSMS_WHATSAPP_ENDPOINT=https://wpsms.configured.cc/api/send/whatsapp
WPSMS_WHATSAPP_METHOD=POST
WPSMS_API_SECRET=
WPSMS_WHATSAPP_ACCOUNT=
WPSMS_WHATSAPP_SECRET_FIELD=secret
WPSMS_WHATSAPP_ACCOUNT_FIELD=account
WPSMS_WHATSAPP_PHONE_FIELD=recipient
WPSMS_WHATSAPP_MESSAGE_FIELD=message
WPSMS_WHATSAPP_TYPE_FIELD=type
WPSMS_WHATSAPP_TYPE_VALUE=text
WPSMS_WHATSAPP_PRIORITY_FIELD=priority
WPSMS_WHATSAPP_PRIORITY_VALUE=
